import std.math;
import std.libc;

fn main() -> i32 {
    print("=== Math Library Demo ===\n");

    // --- 1. Generic Absolute Value ---
    i: i32 = -42;
    f: f64 = -3.14159;
    
    res_i: i32 = std.math.abs<i32>(i);
    res_f: f64 = std.math.abs<f64>(f);

    print("abs(", i, ")      = ", res_i, "\n");
    print("abs(", f, ") = ", res_f, "\n\n");

    // --- 2. Generic Min / Max ---
    a: i64 = 100;
    b: i64 = 250;
    
    smallest: i64 = std.math.min<i64>(a, b);
    largest: i64 = std.math.max<i64>(a, b);

    print("min(", a, ", ", b, ") = ", smallest, "\n");
    print("max(", a, ", ", b, ") = ", largest, "\n\n");

    // --- 3. Generic Clamp ---
    // Clamping a float that is way over the limit
    val: f64 = 15.5;
    lo: f64 = 0.0;
    hi: f64 = 10.0;
    clamped: f64 = std.math.clamp<f64>(val, lo, hi);

    print("clamp(", val, ", ", lo, ", ", hi, ") = ", clamped, "\n\n");

    // --- 4. Advanced Math (f64 native) ---
    pi: f64 = std.math.PI;
    
    // sin(PI / 2) should be 1.0
    sine_val: f64 = std.math.sin(pi / 2.0); 
    
    // sqrt(144) should be 12.0
    root_val: f64 = std.math.sqrt(144.0);   

    print("sin(PI / 2.0)  = ", sine_val, "\n");
    print("sqrt(144.0)    = ", root_val, "\n");

    return 0;
}