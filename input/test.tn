fn fib(n: i32) -> i32 {
    if (n <= 1) { return n; }
    
    prev: i32 = 0;
    curr: i32 = 1;
    
    for (i: i32 = 2; i <= n; i = i + 1) {
        next: i32 = prev + curr;
        prev = curr;
        curr = next;
    }
    
    return curr;
}

fn main() {
    res: i32 = fib(45);
    println(res);
}
