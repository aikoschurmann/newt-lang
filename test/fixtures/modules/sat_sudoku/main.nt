import std;
import std.vec;

alias Allocator = std.mem.Allocator;
alias Arena     = std.arena.Arena;
alias Vec       = std.vec.Vec;

const NUM_VARS: i32 = 729;
enum Val {
    Unassigned,
    True,
    False
}

struct Clause  { lits: i32[]; }
struct Formula {
    clauses: Vec<Clause>;
    assignment: Val[729];
    trail: Vec<i32>;
    var_to_clauses: Vec<Vec<i32>>;
}

fn sv(r: i32, c: i32, v: i32) -> i32 { return (r * 81) + (c * 9) + v + 1; }

fn lit_val(assignment: Val[], lit: i32) -> Val {
    if lit > 0 {
        return assignment[lit as i64 - 1];
    } else {
        val: Val = assignment[-lit as i64 - 1];
        if val == Val.Unassigned { return Val.Unassigned; }
        if val == Val.True { return Val.False; }
        return Val.True;
    }
}

impl Formula {
    fn assign(self: *Formula, var_idx: i32, val: Val) {
        self.assignment[var_idx as i64 - 1] = val;
        self.trail.push(var_idx);
    }

    fn add_clause(self: *Formula, a: Allocator, lits: i32[]) {
        idx: i32 = self.clauses.len as i32;
        self.clauses.push(Clause { lits: a.clone(lits) });
        for (i: i64 = 0; i < lits.len; i += 1) {
            lit: i32 = lits[i];
            var_idx: i32 = lit;
            if var_idx < 0 { var_idx = -var_idx; }
            v: Vec<i32> = self.var_to_clauses.get(var_idx as i64 - 1);
            v.push(idx);
            self.var_to_clauses.set(var_idx as i64 - 1, v);
        }
    }

    fn propagate(self: *Formula, start_trail: i64) -> bool {
        head: i64 = start_trail;
        
        while (head < self.trail.len) {
            var_idx: i32 = self.trail.get(head);
            head += 1;
            
            affected: Vec<i32> = self.var_to_clauses.get(var_idx as i64 - 1);
            
            for (i: i64 = 0; i < affected.len; i += 1) {
                c_idx: i32 = affected.get(i);
                c: Clause = self.clauses.get(c_idx as i64);
                
                unassigned: i32 = 0;
                last_lit: i32 = 0;
                satisfied: bool = false;

                for (j: i64 = 0; j < c.lits.len; j += 1) {
                    v: Val = lit_val(self.assignment, c.lits[j]);
                    if v == Val.True  { satisfied = true; break; }
                    if v == Val.Unassigned { unassigned += 1; last_lit = c.lits[j]; }
                }

                if !satisfied {
                    if unassigned == 0 { return false; }
                    if unassigned == 1 {
                        v_idx: i32 = last_lit;
                        val: Val = Val.True;
                        if v_idx < 0 { 
                            v_idx = -v_idx; 
                            val = Val.False;
                        }
                        self.assign(v_idx, val);
                    }
                }
            }
        }
        return true;
    }

    fn solve(self: *Formula, pick_start: i32) -> i32 {
        trail_start: i64 = self.trail.len;

        if !self.propagate(trail_start) {
            for (i: i64 = trail_start; i < self.trail.len; i += 1) {
                var_idx: i32 = self.trail.get(i);
                self.assignment[var_idx as i64 - 1] = Val.Unassigned;
            }
            self.trail.len = trail_start;
            return -1;
        }

        pick: i32 = -1;
        for (i: i32 = pick_start; i < 729; i += 1) {
            if self.assignment[i as i64] == Val.Unassigned { pick = i; break; }
        }

        if pick == -1 {
            total: i32 = 0;
            for (r: i32 = 0; r < 9; r += 1) {
                for (c: i32 = 0; c < 9; c += 1) {
                    for (v: i32 = 0; v < 9; v += 1) {
                        if (lit_val(self.assignment, sv(r, c, v)) == Val.True) {
                            digit: i32 = v + 1;
                            total = total + (digit * digit);
                        }
                    }
                }
            }
            return total;
        }

        self.assign(pick + 1, Val.True);
        res1: i32 = self.solve(pick + 1);
        if res1 >= 0 { return res1; }

        for (i: i64 = trail_start; i < self.trail.len; i += 1) {
            var_idx: i32 = self.trail.get(i);
            self.assignment[var_idx as i64 - 1] = Val.Unassigned;
        }
        self.trail.len = trail_start;

        self.assign(pick + 1, Val.False);
        res2: i32 = self.solve(pick + 1);
        
        if res2 < 0 {
            for (i: i64 = trail_start; i < self.trail.len; i += 1) {
                var_idx: i32 = self.trail.get(i);
                self.assignment[var_idx as i64 - 1] = Val.Unassigned;
            }
            self.trail.len = trail_start;
        }
        
        return res2;
    }
}

fn build_sudoku(a: Allocator) -> Formula {
    f: Formula;
    alloc_ref: Allocator = a;
    f.clauses.with_capacity(&alloc_ref, 12000);
    f.trail.with_capacity(&alloc_ref, 12000);
    f.var_to_clauses.with_capacity(&alloc_ref, 729);

    for (i: i64 = 0; i < 729; i += 1) { 
        f.assignment[i] = Val.Unassigned; 
        v: Vec<i32>;
        v.with_capacity(&alloc_ref, 32);
        f.var_to_clauses.push(v);
    }

    for (r: i32 = 0; r < 9; r += 1) {
        for (c: i32 = 0; c < 9; c += 1) {
            f.add_clause(a, { 
                sv(r,c,0), sv(r,c,1), sv(r,c,2), 
                sv(r,c,3), sv(r,c,4), sv(r,c,5), 
                sv(r,c,6), sv(r,c,7), sv(r,c,8) 
            });
        }
    }

    for (r: i32 = 0; r < 9; r += 1) {
        for (c: i32 = 0; c < 9; c += 1) {
            for (v1: i32 = 0; v1 < 9; v1 += 1) {
                for (v2: i32 = v1 + 1; v2 < 9; v2 += 1) {
                    f.add_clause(a, { -sv(r,c,v1), -sv(r,c,v2) });
                }
            }
        }
    }

    for (r: i32 = 0; r < 9; r += 1) {
        for (v: i32 = 0; v < 9; v += 1) {
            for (c1: i32 = 0; c1 < 9; c1 += 1) {
                for (c2: i32 = c1 + 1; c2 < 9; c2 += 1) {
                    f.add_clause(a, { -sv(r,c1,v), -sv(r,c2,v) });
                }
            }
        }
    }

    for (c: i32 = 0; c < 9; c += 1) {
        for (v: i32 = 0; v < 9; v += 1) {
            for (r1: i32 = 0; r1 < 9; r1 += 1) {
                for (r2: i32 = r1 + 1; r2 < 9; r2 += 1) {
                    f.add_clause(a, { -sv(r1,c,v), -sv(r2,c,v) });
                }
            }
        }
    }

    for (br: i32 = 0; br < 3; br += 1) {
        for (bc: i32 = 0; bc < 3; bc += 1) {
            for (v: i32 = 0; v < 9; v += 1) {
                for (i1: i32 = 0; i1 < 9; i1 += 1) {
                    for (i2: i32 = i1 + 1; i2 < 9; i2 += 1) {
                        r1: i32 = (br * 3) + (i1 / 3); c1: i32 = (bc * 3) + (i1 % 3);
                        r2: i32 = (br * 3) + (i2 / 3); c2: i32 = (bc * 3) + (i2 % 3);
                        f.add_clause(a, { -sv(r1,c1,v), -sv(r2,c2,v) });
                    }
                }
            }
        }
    }

    grid: *char = "42..6....5..084....87....5.7...5...23..7.2..06...1...5.5....17....308..4....7..68";
    for (i: i64 = 0; i < 81; i += 1) {
        ch: char = grid[i];
        if ch != '.' { 
            val: i32 = (ch as i32) - ('0' as i32); 
            f.add_clause(a, { sv((i / 9) as i32, (i % 9) as i32, val) });
        }
    }

    return f;
}

fn main() -> i32 {
    arena: Arena = Arena.new(20485760);
    defer { arena.destroy(); }

    f: Formula = build_sudoku(arena.get_allocator());
    
    // Initial propagation pass
    for (i: i64 = 0; i < f.clauses.len; i += 1) {
        c: Clause = f.clauses.get(i);
        if c.lits.len == 1 {
            var_idx: i32 = c.lits[0];
            val: Val = Val.True;
            if var_idx < 0 { 
                var_idx = -var_idx; 
                val = Val.False;
            }
            if f.assignment[var_idx as i64 - 1] == Val.Unassigned {
                f.assign(var_idx, val);
            } else if f.assignment[var_idx as i64 - 1] != val {
                return -1; // Conflict in unary clauses
            }
        }
    }

    if !f.propagate(0) {
        return -1;
    }

    result: i32 = f.solve(0);
    print(result);
    return result;
}
