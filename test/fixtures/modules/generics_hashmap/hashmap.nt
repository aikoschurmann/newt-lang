import std;

pub struct MapEntry<K, V> {
    key: K;
    value: V;
    occupied: bool;
}

pub struct HashMap<K, V> {
    entries: *MapEntry<K, V>;
    size: i32;
    capacity: i32;
}

impl<K, V> HashMap<K, V> {
    pub fn init(self: *HashMap<K, V>, cap: i32) {
        self.capacity = cap;
        self.size = 0;
        self.entries = @alloc(MapEntry<K, V>, std.heap.allocator, cap as i64);
        for (i: i32 = 0; i < cap; i = i + 1) {
            self.entries[i].occupied = false;
        }
    }

    pub fn deinit(self: *HashMap<K, V>) {
        @free(std.heap.allocator, self.entries);
    }

    pub fn put(self: *HashMap<K, V>, key: K, value: V) -> bool {
        if (self.size * 2 >= self.capacity) {
            self.resize(self.capacity * 2);
        }

        h: i32 = (key as i32) % self.capacity;
        if (h < 0) { h = h + self.capacity; }
        for (i: i32 = 0; i < self.capacity; i = i + 1) {
            idx: i32 = (h + i) % self.capacity;
            if (!self.entries[idx].occupied) {
                self.entries[idx].key = key;
                self.entries[idx].value = value;
                self.entries[idx].occupied = true;
                self.size = self.size + 1;
                return true;
            }
            if (self.entries[idx].key == key) {
                self.entries[idx].value = value;
                return true;
            }
        }
        return false;
    }

    pub fn get(self: *HashMap<K, V>, key: K) -> V {
        h: i32 = (key as i32) % self.capacity;
        if (h < 0) { h = h + self.capacity; }
        for (i: i32 = 0; i < self.capacity; i = i + 1) {
            idx: i32 = (h + i) % self.capacity;
            if (!self.entries[idx].occupied) {
                break;
            }
            if (self.entries[idx].key == key) {
                return self.entries[idx].value;
            }
        }
        return 0 as V;
    }

    pub fn resize(self: *HashMap<K, V>, new_cap: i32) {
        old_entries: *MapEntry<K, V> = self.entries;
        old_cap: i32 = self.capacity;

        self.capacity = new_cap;
        self.size = 0;
        self.entries = @alloc(MapEntry<K, V>, std.heap.allocator, new_cap as i64);
        for (i: i32 = 0; i < new_cap; i = i + 1) {
            self.entries[i].occupied = false;
        }

        for (i: i32 = 0; i < old_cap; i = i + 1) {
            if (old_entries[i].occupied) {
                self.put(old_entries[i].key, old_entries[i].value);
            }
        }

        @free(std.heap.allocator, old_entries);
    }
}
