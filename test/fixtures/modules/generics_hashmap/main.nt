import .hashmap { HashMap };

fn main() -> i32 {
    map: HashMap<i32, i32>;
    map.init(4);

    map.put(15, 100);
    map.put(23, 200); // load factor = 0.5 -> triggers resize to 8
    map.put(31, 300); 
    map.put(39, 400); // load factor = 0.5 -> triggers resize to 16

    map.put(23, 250); // update

    res: i32 = map.get(15) + map.get(23) + map.get(31) + map.get(39);

    map.deinit();

    return res;
}
