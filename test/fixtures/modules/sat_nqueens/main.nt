import std;
alias Arena     = std.arena.Arena;
alias Allocator = std.mem.Allocator;
alias Vec       = std.vec.Vec;
alias printf    = std.libc.printf;

const N: i32 = 16;
const NUM_VARS: i32 = N * N;

alias Val = u8;
const VAL_UNASSIGNED: Val = 0;
const VAL_TRUE: Val = 1;
const VAL_FALSE: Val = 2;

struct ClauseRef {
    offset: usize;
    len: usize;
}

struct Formula {
    alloc_ref: *Allocator;
    clause_data: Vec<i32>;
    clauses: Vec<ClauseRef>;
    watches: Vec<Vec<i32>>; 
    assignment: Val[256];
    trail: Vec<i32>;
    unassigned_counts: i32[16];
}

fn sv(r: i32, c: i32) -> i32 { return (r * N) + c + 1; }

fn lit_to_idx(lit: i32) -> usize {
    if (lit > 0) { return (lit as usize) * 2; }
    return ((-lit) as usize) * 2 + 1;
}

fn lit_val(assignment: Val[], lit: i32) -> Val {
    if (lit > 0) {
        return assignment[lit as usize - 1];
    } else {
        val: Val = assignment[-lit as usize - 1];
        if (val == VAL_UNASSIGNED) { return VAL_UNASSIGNED; }
        if (val == VAL_TRUE) { return VAL_FALSE; }
        return VAL_TRUE;
    }
}

impl Formula {
    fn assign(self: *Formula, var_idx: i32, val: Val) {
        self.assignment[var_idx as usize - 1] = val;
        self.trail.push(var_idx);
        
        row_idx: usize = ((var_idx - 1) / N) as usize;
        self.unassigned_counts[row_idx] = self.unassigned_counts[row_idx] - 1;
    }

    fn add_clause(self: *Formula, lits: i32[]) {
        c_idx: i32 = self.clauses.len as i32;
        offset: usize = self.clause_data.len;
        for (i: usize = 0; i < lits.len; i += 1) {
            self.clause_data.push(lits[i]);
        }
        self.clauses.push(ClauseRef { offset: offset, len: lits.len });
        
        if (lits.len <= 1) { return; }
        
        l0: i32 = lits[0];
        l1: i32 = lits[1];
        if (lits.len == 2) {
            // printf("Added binary clause\n");
        }
        
        v0: Vec<i32> = self.watches.get(lit_to_idx(l0));
        v0.push(c_idx);
        self.watches.set(lit_to_idx(l0), v0);
        
        v1: Vec<i32> = self.watches.get(lit_to_idx(l1));
        v1.push(c_idx);
        self.watches.set(lit_to_idx(l1), v1);
    }
    
    fn add_clause_vec(self: *Formula, lits: *Vec<i32>) {
        c_idx: i32 = self.clauses.len as i32;
        offset: usize = self.clause_data.len;
        for (i: usize = 0; i < lits.len; i += 1) {
            self.clause_data.push(lits.get(i));
        }
        self.clauses.push(ClauseRef { offset: offset, len: lits.len });
        
        if (lits.len <= 1) { return; }
        
        l0: i32 = lits.get(0);
        l1: i32 = lits.get(1);
        
        v0: Vec<i32> = self.watches.get(lit_to_idx(l0));
        v0.push(c_idx);
        self.watches.set(lit_to_idx(l0), v0);
        
        v1: Vec<i32> = self.watches.get(lit_to_idx(l1));
        v1.push(c_idx);
        self.watches.set(lit_to_idx(l1), v1);
    }

    fn propagate(self: *Formula, start_trail: usize) -> bool {
        head: usize = start_trail;
        
        while (head < self.trail.len) {
            var_idx: i32 = self.trail.get(head);
            head += 1;
            
            val: Val = self.assignment[var_idx as usize - 1];
            
            falsified_lit: i32 = 0;
            if (val == VAL_TRUE) {
                falsified_lit = -var_idx;
            } else if (val == VAL_FALSE) {
                falsified_lit = var_idx;
            } else {
                continue;
            }
            
            watch_idx: usize = lit_to_idx(falsified_lit);
            affected: Vec<i32> = self.watches.get(watch_idx);
            
            new_affected: Vec<i32>;
            new_affected.with_capacity(self.alloc_ref, affected.len);
            
            conflict: bool = false;
            
            for (i: usize = 0; i < affected.len; i += 1) {
                c_idx: i32 = affected.get(i);
                if (conflict) {
                    new_affected.push(c_idx);
                    continue;
                }
                
                c_ref: ClauseRef = self.clauses.get(c_idx as usize);
                l0: i32 = self.clause_data.get(c_ref.offset);
                l1: i32 = self.clause_data.get(c_ref.offset + 1);
                
                if (l0 == falsified_lit) {
                    l0 = l1;
                    l1 = falsified_lit;
                    self.clause_data.set(c_ref.offset, l0);
                    self.clause_data.set(c_ref.offset + 1, l1);
                }
                
                v0: Val = lit_val(self.assignment, l0);
                if (v0 == VAL_TRUE) {
                    new_affected.push(c_idx);
                    continue;
                }
                
                found_new_watch: bool = false;
                for (j: usize = 2; j < c_ref.len; j += 1) {
                    lk: i32 = self.clause_data.get(c_ref.offset + j);
                    vk: Val = lit_val(self.assignment, lk);
                    if (vk != VAL_FALSE) {
                        self.clause_data.set(c_ref.offset + 1, lk);
                        self.clause_data.set(c_ref.offset + j, l1);
                        
                        w: Vec<i32> = self.watches.get(lit_to_idx(lk));
                        w.push(c_idx);
                        self.watches.set(lit_to_idx(lk), w);
                        
                        found_new_watch = true;
                        break;
                    }
                }
                
                if (found_new_watch) {
                    continue;
                }
                
                new_affected.push(c_idx);
                
                if (v0 == VAL_FALSE) {
                    conflict = true;
                } else if (v0 == VAL_UNASSIGNED) {
                    v_idx: i32 = l0;
                    assign_val: Val = VAL_TRUE;
                    if (v_idx < 0) {
                        v_idx = -v_idx;
                        assign_val = VAL_FALSE;
                    }
                    self.assign(v_idx, assign_val);
                }
            }
            
            affected.free();
            self.watches.set(watch_idx, new_affected);
            
            if (conflict) { return false; }
        }
        return true;
    }

    fn solve(self: *Formula, head: usize) -> i32 {
        trail_start: usize = self.trail.len;

        if (!self.propagate(head)) {
            for (i: usize = trail_start; i < self.trail.len; i += 1) {
                var_idx: i32 = self.trail.get(i);
                self.assignment[var_idx as usize - 1] = VAL_UNASSIGNED;
                row_idx: usize = ((var_idx - 1) / N) as usize;
                self.unassigned_counts[row_idx] = self.unassigned_counts[row_idx] + 1;
            }
            self.trail.len = trail_start;
            return -1;
        }

        pick_row: i32 = -1;
        min_unassigned: i32 = N + 1;
        for (r: usize = 0; r < (N as usize); r += 1) {
            unassigned: i32 = self.unassigned_counts[r];
            if (unassigned > 0) {
                solved: bool = false;
                for (c: i32 = 0; c < N; c += 1) {
                    var_idx: i32 = ((r as i32) * N) + c + 1;
                    if (self.assignment[var_idx as usize - 1] == VAL_TRUE) {
                        solved = true;
                        break;
                    }
                }
                if (!solved && unassigned < min_unassigned) {
                    min_unassigned = unassigned;
                    pick_row = r as i32;
                    if (min_unassigned == 1) { break; }
                }
            }
        }
        if (pick_row == -1) {
            total: i32 = 0;
            for (r: i32 = 0; r < N; r += 1) {
                for (c: i32 = 0; c < N; c += 1) {
                    if ((lit_val(self.assignment, sv(r, c)) == VAL_TRUE)) {
                        total = total + c;
                    }
                }
            }
            return total;
        }

        pick: i32 = -1;
        for (c: i32 = 0; c < N; c += 1) {
            var_idx: i32 = (pick_row * N) + c + 1;
            if (self.assignment[var_idx as usize - 1] == VAL_UNASSIGNED) {
                pick = var_idx;
                break;
            }
        }

        self.assign(pick, VAL_TRUE);
        res1: i32 = self.solve(trail_start);
        if (res1 >= 0) { return res1; }

        for (i: usize = trail_start; i < self.trail.len; i += 1) {
            var_idx: i32 = self.trail.get(i);
            self.assignment[var_idx as usize - 1] = VAL_UNASSIGNED;
            row_idx: usize = ((var_idx - 1) / N) as usize;
            self.unassigned_counts[row_idx] = self.unassigned_counts[row_idx] + 1;
        }
        self.trail.len = trail_start;

        self.assign(pick, VAL_FALSE);
        res2: i32 = self.solve(trail_start);
        
        if (res2 < 0) {
            for (i: usize = trail_start; i < self.trail.len; i += 1) {
                var_idx: i32 = self.trail.get(i);
                self.assignment[var_idx as usize - 1] = VAL_UNASSIGNED;
                row_idx: usize = ((var_idx - 1) / N) as usize;
                self.unassigned_counts[row_idx] = self.unassigned_counts[row_idx] + 1;
            }
            self.trail.len = trail_start;
        }
        
        return res2;
    }
    
    fn init(self: *Formula, a: *Allocator) {
        self.alloc_ref = a;
        self.clauses.with_capacity(a, 20000);
        self.trail.with_capacity(a, 2000);
        self.clause_data.with_capacity(a, 60000);
        watches_size: usize = (NUM_VARS * 2 + 2) as usize;
        self.watches.with_capacity(a, watches_size);

        for (i: usize = 0; i < (N as usize); i += 1) {
            self.unassigned_counts[i] = N;
        }

        for (i: usize = 0; i < (NUM_VARS as usize); i += 1) { 
            self.assignment[i] = VAL_UNASSIGNED; 
        }

        for (i: usize = 0; i < watches_size; i += 1) {
            v: Vec<i32>;
            v.with_capacity(a, 32);
            self.watches.push(v);
        }
    }
}

fn build_nqueens(f: *Formula) {
    // 1. One queen per row
    for (r: i32 = 0; r < N; r += 1) {
        // ALO
        alo: Vec<i32>;
        alo.with_capacity(f.alloc_ref, N as usize);
        for (c: i32 = 0; c < N; c += 1) {
            alo.push(sv(r, c));
        }
        f.add_clause_vec(&alo);
        alo.free();
        
        // AMO
        for (c1: i32 = 0; c1 < N; c1 += 1) {
            for (c2: i32 = c1 + 1; c2 < N; c2 += 1) {
                amo: Vec<i32>;
                amo.with_capacity(f.alloc_ref, 2 as usize);
                amo.push(-sv(r, c1));
                amo.push(-sv(r, c2));
                f.add_clause_vec(&amo);
                amo.free();
            }
        }
    }
    
    // 2. One queen per col
    for (c: i32 = 0; c < N; c += 1) {
        // ALO
        alo: Vec<i32>;
        alo.with_capacity(f.alloc_ref, N as usize);
        for (r: i32 = 0; r < N; r += 1) {
            alo.push(sv(r, c));
        }
        f.add_clause_vec(&alo);
        alo.free();
        
        // AMO
        for (r1: i32 = 0; r1 < N; r1 += 1) {
            for (r2: i32 = r1 + 1; r2 < N; r2 += 1) {
                amo: Vec<i32>;
                amo.with_capacity(f.alloc_ref, 2 as usize);
                amo.push(-sv(r1, c));
                amo.push(-sv(r2, c));
                f.add_clause_vec(&amo);
                amo.free();
            }
        }
    }

    // 3. Diagonals AMO
    for (r1: i32 = 0; r1 < N; r1 += 1) {
        for (c1: i32 = 0; c1 < N; c1 += 1) {
            // Main diagonal
            d: i32 = 1;
            while ((r1 + d < N) && (c1 + d < N)) {
                amo: Vec<i32>;
                amo.with_capacity(f.alloc_ref, 2 as usize);
                amo.push(-sv(r1, c1));
                amo.push(-sv(r1 + d, c1 + d));
                f.add_clause_vec(&amo);
                amo.free();
                d += 1;
            }
            
            // Anti-diagonal
            d = 1;
            while ((r1 + d < N) && (c1 - d >= 0)) {
                amo: Vec<i32>;
                amo.with_capacity(f.alloc_ref, 2 as usize);
                amo.push(-sv(r1, c1));
                amo.push(-sv(r1 + d, c1 - d));
                f.add_clause_vec(&amo);
                amo.free();
                d += 1;
            }
        }
    }
}

fn main() -> i32 {
    arena: Arena = Arena.new(20485760 as usize);
    defer { arena.destroy(); }
    
    alloc_ref: Allocator = arena.get_allocator();

    f: Formula;
    f.init(&alloc_ref);
    build_nqueens(&f);
    
    // Initial propagation pass
    for (i: usize = 0; i < f.clauses.len; i += 1) {
        c: ClauseRef = f.clauses.get(i);
        if (c.len == 1) {
            var_idx: i32 = f.clause_data.get(c.offset);
            val: Val = VAL_TRUE;
            if (var_idx < 0) { 
                var_idx = -var_idx; 
                val = VAL_FALSE;
            }
            if (f.assignment[var_idx as usize - 1] == VAL_UNASSIGNED) {
                f.assign(var_idx, val);
            } else if (f.assignment[var_idx as usize - 1] != val) {
                return -1; // Conflict in unary clauses
            }
        }
    }

    if (!f.propagate(0)) {
        return -1;
    }

    result: i32 = f.solve(f.trail.len);
    // Return >= 0 if SAT, -1 if UNSAT
    return result;
}
