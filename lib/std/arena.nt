import std.mem;
import std.heap;

pub struct Arena {
    buffer: *char; // raw bytes
    capacity: usize;
    offset: usize;
    backing_allocator: std.mem.Allocator;
}

fn arena_alloc_impl(ctx: *void, size: usize) -> *void {
    arena: *Arena = ctx as *Arena;
    return arena.alloc(size);
}

fn arena_free_impl(ctx: *void, ptr: *void) -> void {
}

impl Arena {
    // Create an Arena with a specific backing allocator.
    pub fn new(backing: std.mem.Allocator, size: usize) -> Arena {
        buf: *char = backing.alloc(size) as *char;
        return Arena {
            buffer: buf,
            capacity: size,
            offset: 0,
            backing_allocator: backing
        };
    }

    // Create an Arena using the default heap allocator.
    pub fn new(size: usize) -> Arena {
        return Arena.new(std.heap.allocator, size);
    }

    pub fn alloc(self: *Arena, size: usize) -> *void {
        // Check for Out-Of-Memory
        if (self.offset + size) > self.capacity {
            return null; 
        }
        
        // Bump the pointer
        ptr: *void = ((self.buffer as usize) + self.offset) as *void;
        self.offset = self.offset + size;
        return ptr;
    }

    // Overloaded alloc for count * size
    pub fn alloc(self: *Arena, count: usize, size: usize) -> *void {
        return self.alloc(count * size);
    }

    // Arena frees are no-ops: memory is reclaimed in bulk by .reset() or .destroy().
    pub fn free(self: *Arena, ptr: *void) -> void {
    }

    // Returns how many bytes are still available.
    pub fn remaining(self: *Arena) -> usize {
        return self.capacity - self.offset;
    }

    pub fn reset(self: *Arena) -> void {
        self.offset = 0;
    }

    pub fn get_allocator(self: *Arena) -> std.mem.Allocator {
        return std.mem.Allocator {
            ctx: self as *void,
            _alloc: arena_alloc_impl,
            _free: arena_free_impl
        };
    }

    pub fn destroy(self: *Arena) -> void {
        self.backing_allocator.free(self.buffer as *void);
    }
}
