pub struct Allocator {
    ctx: *void;
    _alloc: fn(*void, usize) -> *void;
    _free: fn(*void, *void) -> void;
}

impl Allocator {
    pub fn alloc(self: *Allocator, size: usize) -> *void {
        return self._alloc(self.ctx, size);
    }

    pub fn alloc(self: *Allocator, count: usize, size: usize) -> *void {
        return self.alloc(count * size);
    }

    pub fn free(self: *Allocator, ptr: *void) -> void {
        self._free(self.ctx, ptr);
    }

    pub fn clone<T>(self: *Allocator, src: T[]) -> T[] {
        dest: T[] = @alloc(T, self, src.len);
        for (i: usize = 0; i < src.len; i += 1) { dest[i] = src[i]; }
        return dest;
    }
}
