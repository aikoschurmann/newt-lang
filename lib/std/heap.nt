import std.libc;
import std.mem;

fn heap_alloc_impl(_ctx: *void, size: usize) -> *void {
    return std.libc.malloc(size);
}

fn heap_free_impl(_ctx: *void, ptr: *void) -> void {
    std.libc.free(ptr);
}

pub const allocator: std.mem.Allocator = std.mem.Allocator {
    ctx: null,
    _alloc: heap_alloc_impl,
    _free: heap_free_impl
};
