import .mem;
// import std.libc;

pub struct Vec<T> {
    data: *T;
    len: usize;
    cap: usize;
    allocator: *mem.Allocator;
}

impl<T> Vec<T> {
    pub fn init(self: *Vec<T>, allocator: *mem.Allocator) -> void {
        self.data = null as *T;
        self.len = 0;
        self.cap = 0;
        self.allocator = allocator;
    }

    pub fn with_capacity(self: *Vec<T>, allocator: *mem.Allocator, capacity: usize) -> void {
        self.data = null as *T;
        if (capacity > 0) {
            self.data = @alloc(T, allocator, capacity);
        }
        self.len = 0;
        self.cap = capacity;
        self.allocator = allocator;
    }

    pub fn free(self: *Vec<T>) -> void {
        if (self.cap > 0) {
            @free(self.allocator, self.data);
            self.data = null as *T;
            self.cap = 0;
            self.len = 0;
        }
    }

    pub fn push(self: *Vec<T>, item: T) -> void {
        if (self.len >= self.cap) {
            new_cap: usize = self.cap * 2;
            if (new_cap == 0) {
                new_cap = 8;
            }
            
            new_data: *T = @alloc(T, self.allocator, new_cap);
            if (self.cap > 0) {
                // Copy existing data
                i: usize = 0;
                while (i < self.len) {
                    new_data[i] = self.data[i];
                    i = i + 1;
                }
                @free(self.allocator, self.data);
            }
            
            self.data = new_data;
            self.cap = new_cap;
        }
        
        self.data[self.len] = item;
        self.len = self.len + 1;
    }

    pub fn pop(self: *Vec<T>) -> T {
        // Warning: Calling pop on an empty vector is UB
        self.len = self.len - 1;
        return self.data[self.len];
    }
    
    pub fn get(self: *Vec<T>, index: usize) -> T {
        return self.data[index];
    }

    pub fn get_ptr(self: *Vec<T>, index: usize) -> *T {
        return self.data + index;
    }

    pub fn set(self: *Vec<T>, index: usize, value: T) -> void {
        self.data[index] = value;
    }
    
    pub fn clear(self: *Vec<T>) -> void {
        self.len = 0;
    }

    pub fn is_empty(self: *Vec<T>) -> bool {
        return self.len == 0;
    }
}
